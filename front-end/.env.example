# =============================================================================
# mmm-os — Front-end (UI) environment (example)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# UI database (Prisma). This is the front-end's OWN database, separate from the
# backend (SQLAlchemy) database. SQLite in dev; swap to Postgres later by
# changing the datasource `provider` in prisma/schema.prisma AND this URL.
# See docs/architecture.md (Database Strategy).
# -----------------------------------------------------------------------------

# Local development default (SQLite file under prisma/):
DATABASE_URL="file:./dev.db"

# Production / integration (Postgres) — uncomment, set the provider to
# "postgresql" in prisma/schema.prisma, and set this URL when swapping:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mmm_os_ui?schema=public"

# -----------------------------------------------------------------------------
# Backend API target (used by next.config.mjs rewrites in dev).
# The UI talks to the backend via API — it never reads the backend DB directly.
# -----------------------------------------------------------------------------
# MMM_OS_API_URL="http://127.0.0.1:8000"
