# =============================================================================
# mmm-os — Backend environment (example)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend database (SQLAlchemy). Two independent databases exist in this system;
# this is the BACKEND one. The UI (Prisma) database is configured separately in
# `front-end/.env`. See docs/architecture.md (Section: Database Strategy).
#
# Portability is a hard requirement: switch SQLite -> Postgres by changing this
# URL ONLY. Do not hardcode a dialect anywhere in code.
# -----------------------------------------------------------------------------

# Local development default (SQLite file in the repo root):
BACKEND_DATABASE_URL=sqlite:///./mmm_os.db

# Production / integration (Postgres) — uncomment and set when swapping:
# BACKEND_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/mmm_os

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment name: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Future (documented decisions; wired in later phases — commented placeholders).
# These are recorded here so the resolved open questions are visible in config,
# but the app does NOT read them yet. See docs/open-questions.md + docs/architecture.md.
# -----------------------------------------------------------------------------

# Object storage (Phase 1 / ADR-006, OQ-INIT.1): abstraction over local FS (dev)
# and S3-compatible storage (prod).
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./_storage
# STORAGE_S3_BUCKET=mmm-os-raw
# STORAGE_S3_ENDPOINT_URL=            # e.g. http://localhost:9000 for MinIO
# STORAGE_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Async queue (Phase 7 / ADR-007, OQ-7.1): Celery + Redis (broker + result backend).
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AI suggestion layer (Phase 5 / ADR-008, OQ-5.1/INIT.4): Claude via the Anthropic API.
# ANTHROPIC_API_KEY=
