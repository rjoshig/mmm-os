# =============================================================================
# mmm-os — Backend environment (example)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend database (SQLAlchemy). Two independent databases exist in this system;
# this is the BACKEND one. The UI (Prisma) database is configured separately in
# `front-end/.env`. See docs/architecture.md (Section: Database Strategy).
#
# Portability is a hard requirement: switch SQLite -> Postgres by changing this
# URL ONLY. Do not hardcode a dialect anywhere in code.
# -----------------------------------------------------------------------------

# Local development default (SQLite file in the repo root):
BACKEND_DATABASE_URL=sqlite:///./mmm_os.db

# Production / integration (Postgres) — uncomment and set when swapping:
# BACKEND_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/mmm_os

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Environment name: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS origins allowed to call the API from a browser (the Review UI, Phase 6):
# CORS_ALLOW_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (Phase 00.5, CC-11) + Secrets (Phase 00.6, CC-12)
# -----------------------------------------------------------------------------
# Require a valid session on every feature endpoint. Off by default so dev/tests
# run unauthenticated; set true to enforce (the Review UI expects this).
# AUTH_ENABLED=true
# SESSION_TTL_HOURS=12
# On startup (when AUTH_ENABLED=true) seed a default tenant + admin:
# SEED_DEFAULT_ADMIN=true
# DEFAULT_ADMIN_EMAIL=admin
# DEFAULT_ADMIN_PASSWORD=admin123      # CHANGE in any real deployment
# DEFAULT_TENANT_SLUG=default
#
# Secrets store (Phase 00.6): "local" encrypts secrets on disk under a key derived
# from SECRET_MASTER_KEY. Production swaps to a managed KMS/vault backend.
# SECRETS_BACKEND=local
# SECRETS_LOCAL_PATH=./_secrets
# SECRET_MASTER_KEY=change-me-to-a-long-random-string   # NEVER commit a real key

# -----------------------------------------------------------------------------
# Future (documented decisions; wired in later phases — commented placeholders).
# These are recorded here so the resolved open questions are visible in config,
# but the app does NOT read them yet. See docs/open-questions.md + docs/architecture.md.
# -----------------------------------------------------------------------------

# Object storage (Phase 1 / ADR-006, OQ-INIT.1): abstraction over local FS (dev)
# and S3-compatible storage (prod).
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./_storage
# STORAGE_S3_BUCKET=mmm-os-raw
# STORAGE_S3_ENDPOINT_URL=            # e.g. http://localhost:9000 for MinIO
# STORAGE_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Path-based ("landing zone") ingestion (Phase 01.4): comma-separated ABSOLUTE
# directories the backend may read files from BY PATH, so large files are ingested
# by reference instead of a browser upload. Empty/unset disables the feature. Every
# ingest-by-path request is validated to sit within one of these roots (no traversal).
# INGEST_LANDING_ROOTS=/data/landing,/mnt/nfs/marketing-drops

# Async queue (Phase 7 / ADR-007, OQ-7.1): Celery + Redis (broker + result backend).
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AI suggestion layer (Phase 5 / ADR-008): dual OpenAI + Anthropic, OFF by default.
# Switch provider/model with config only. With LLM_PROVIDER=auto the provider is
# inferred from the model name (gpt*/o* -> OpenAI, claude* -> Anthropic).
# Alternatively point LLM_CONFIG_FILE at a JSON file (see llm.config.example.json);
# these env vars override the JSON file.
# LLM_ENABLED=false
# LLM_PROVIDER=auto            # auto | openai | anthropic
# LLM_MODEL=gpt-4o-mini        # e.g. gpt-4o-mini (OpenAI) or claude-... (Anthropic)
# LLM_API_KEY=                 # or use OPENAI_API_KEY / ANTHROPIC_API_KEY below
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_BASE_URL=                # optional: OpenAI-compatible endpoint
# LLM_CONFIG_FILE=./llm.config.json
# LLM_CONFIDENCE_AUTOFILL=0.85
# LLM_CONFIDENCE_FLAG=0.5

# LLM cost controls (Phase 05.1, CC-13): per-tenant daily caps (0 = unlimited; a
# per-tenant llm_budget row overrides these), response caching, and model-tier
# routing (cheap default, strong for hard cases).
# LLM_TENANT_DAILY_TOKEN_CAP=0
# LLM_TENANT_DAILY_CALL_CAP=0
# LLM_CACHE_ENABLED=true
# LLM_MODEL_CHEAP=gpt-4o-mini
# LLM_MODEL_STRONG=gpt-4o
