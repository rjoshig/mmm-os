# ---------------------------------------------------------------------------
# Secrets & environment
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
front-end/.env
front-end/.env.*
!front-end/.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
.uv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---------------------------------------------------------------------------
# Local databases (SQLite dev files) — never commit data
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# Local LLM config (only the example is committed)
llm.config.json
front-end/prisma/*.db
front-end/prisma/dev.db*

# Local object storage (dev uploads — immutable raw files, never commit)
_storage/

# Local encrypted secret store (dev SecretStore backend — never commit)
_secrets/

# ---------------------------------------------------------------------------
# Node / Next.js
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
next-env.d.ts
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Prisma generated client
front-end/node_modules/.prisma/

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Office temp/lock files
~$*
**/~$*
